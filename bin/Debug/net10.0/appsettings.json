{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "StorageType": "Memory",
    "Policies": {
      "Default": {
        "PermitLimit": 3,
        "WindowSeconds": 10
      },
      "Premium": {
        "PermitLimit": 10,
        "WindowSeconds": 10
      }
    }
  }
}
